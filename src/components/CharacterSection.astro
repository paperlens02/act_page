---
// 第二部分：角色介绍 - 双角色展示，半身立绘靠边站，文字居中错开
---
<section class="characters snap-section" id="characters">
  <div class="characters-inner">
    <!-- Rechor - 左侧立绘 -->
    <div class="char-portrait char-left char-reveal char-reveal-left">
      <img src="/Resources/Character_Rechor_1600x1600.png" alt="律可儿 Rechor" class="char-shadow" aria-hidden="true" />
      <img
        src="/Resources/Character_Rechor_1600x1600.png"
        alt="律可儿 Rechor"
        class="char-img"
      />
    </div>

    <!-- 中间文字区域 -->
    <div class="char-text-area char-reveal char-reveal-center">
      <!-- Rechor 文字 - 偏上 -->
      <div class="char-text char-text-top" style="--bright: #BCDE3C; --dark: #353638;">
        <h2 class="char-name" data-i18n="character.rechor.name">律可儿 Rechor</h2>
        <p class="char-desc" data-i18n="character.rechor.desc">
          来源不明的维修机器人，一直在里世界的实验室中负责日常维护。看似笨拙却总能交出能用的设备。胸口和腰间的微型显示屏时常闪烁着未知讯息。她似乎拥有超越礼貌的情感……但自己还没有意识到。
        </p>
      </div>

      <!-- Eiria 文字 - 偏下 -->
      <div class="char-text char-text-bottom" style="--bright: #EED393; --dark: #2A2652;">
        <h2 class="char-name" data-i18n="character.eiria.name">小A Eiria</h2>
        <p class="char-desc" data-i18n="character.eiria.desc">
          大大咧咧的活力少女，真名 Eiria。在表世界遭到追杀时意外坠入里世界，发现了父亲留下的实验室。手持传家法杖，决心实施"细胞调律计划"，为人类的潜意识注入灵性。叛逆而坚毅，偶尔流露出大小姐气质。
        </p>
      </div>
    </div>

    <!-- Eiria - 右侧立绘 -->
    <div class="char-portrait char-right char-reveal char-reveal-right">
      <img src="/Resources/Character_Eiria_1600x1600.png" alt="小A Eiria" class="char-shadow" aria-hidden="true" />
      <img
        src="/Resources/Character_Eiria_1600x1600.png"
        alt="小A Eiria"
        class="char-img"
      />
    </div>
  </div>
</section>

<style>
  @keyframes slideInLeft {
    from { opacity: 0; transform: translateX(-40px); }
    to { opacity: 1; transform: translateX(0); }
  }
  @keyframes slideInRight {
    from { opacity: 0; transform: translateX(40px); }
    to { opacity: 1; transform: translateX(0); }
  }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .characters {
    position: relative;
    background-color: #0e1e30;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 80px 0 10rem;
    overflow: hidden;
  }

  .characters::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 160px;
    background: linear-gradient(to bottom, rgba(8, 16, 32, 0) 0%, rgba(8, 16, 32, 1) 100%);
    z-index: 2;
    pointer-events: none;
  }

  .characters::before {
    content: '';
    position: absolute;
    inset: -10px;
    background: url('/Resources/bg_lab.jpg') center center / cover no-repeat;
    filter: blur(2px) brightness(0.8) contrast(1) saturate(1.5);
    z-index: 0;
    transform: scale(1.05);
  }

  .characters-inner {
    width: 100%;
    max-width: 1400px;
    display: flex;
    align-items: stretch;
    position: relative;
    z-index: 1;
  }

  /* 立绘容器 - 靠边站 */
  .char-portrait {
    position: relative;
    z-index: 1;
    width: 25vw;
    max-width: 350px;
    min-width: 200px;
    flex-shrink: 0;
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }

  .char-left {
    justify-content: center;
  }

  .char-right {
    justify-content: center;
  }

  /* C1: 立绘立体投影（在主立绘背后） */
  .char-portrait {
    overflow: visible;
  }
  .char-shadow {
    position: absolute;
    top: 8px;
    left: 18px;
    width: auto;
    height: 80vh;
    object-fit: contain;
    object-position: top center;
    filter: blur(14px) brightness(0.15) saturate(2);
    opacity: 0.55;
    z-index: -1;
    pointer-events: none;
    -webkit-mask-image: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 1) 0%,
      rgba(0, 0, 0, 1) 60%,
      rgba(0, 0, 0, 0.4) 80%,
      rgba(0, 0, 0, 0) 100%
    );
    mask-image: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 1) 0%,
      rgba(0, 0, 0, 1) 60%,
      rgba(0, 0, 0, 0.4) 80%,
      rgba(0, 0, 0, 0) 100%
    );
  }

  .char-img {
    width: auto;
    height: 80vh;
    object-fit: contain;
    object-position: top center;
    /* 渐变淡出 - 上半身清晰，底部柔和融入背景 */
    -webkit-mask-image: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 1) 0%,
      rgba(0, 0, 0, 1) 60%,
      rgba(0, 0, 0, 0.5) 80%,
      rgba(0, 0, 0, 0) 100%
    );
    mask-image: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 1) 0%,
      rgba(0, 0, 0, 1) 60%,
      rgba(0, 0, 0, 0.5) 80%,
      rgba(0, 0, 0, 0) 100%
    );
  }

  /* 中间文字区域 */
  .char-text-area {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 2rem 3rem;
    gap: 3rem;
    position: relative;
    z-index: 2;
  }

  .char-text {
    max-width: 400px;
  }

  .char-text-top {
    align-self: flex-start;
    text-align: left;
  }

  .char-text-bottom {
    align-self: flex-end;
    text-align: right;
  }

  /* 主题色描边文字 */
  .char-name {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    color: var(--bright);
    text-shadow:
      -2px -2px 0 var(--dark),
      2px -2px 0 var(--dark),
      -2px 2px 0 var(--dark),
      2px 2px 0 var(--dark),
      0 0 12px var(--dark),
      0 0 24px var(--dark);
    margin-bottom: 1rem;
    letter-spacing: 0.06em;
  }

  .char-desc {
    font-size: clamp(0.9rem, 1.5vw, 1.05rem);
    line-height: 1.9;
    color: rgba(255, 255, 255, 0.8);
    text-shadow:
      0 1px 4px rgba(0, 0, 0, 0.9),
      0 0 8px rgba(0, 0, 0, 0.9);
  }

  /* C4: 入场动画（由 IntersectionObserver 添加 is-visible 触发） */
  .char-reveal {
    opacity: 0;
    will-change: transform, opacity;
  }
  .char-reveal.is-visible {
    animation-duration: 1s;
    animation-timing-function: cubic-bezier(0.2, 0.7, 0.3, 1);
    animation-fill-mode: forwards;
  }
  .char-reveal-left.is-visible { animation-name: slideInLeft; }
  .char-reveal-right.is-visible { animation-name: slideInRight; animation-delay: 0.15s; }
  .char-reveal-center.is-visible { animation-name: fadeUp; animation-delay: 0.3s; }

  /* 移动端适配：竖向堆叠 */
  @media (max-width: 768px) {
    .characters-inner {
      flex-direction: column;
      align-items: center;
    }

    .char-portrait {
      width: 200px;
      min-width: unset;
    }

    .char-img {
      height: 300px;
    }

    .char-text-area {
      padding: 1rem 2rem;
      gap: 2rem;
    }

    .char-text {
      max-width: 100%;
      text-align: center;
      align-self: center;
    }

    .char-text-top,
    .char-text-bottom {
      text-align: center;
      align-self: center;
    }
  }
</style>
