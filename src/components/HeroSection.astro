---
// 第一部分：游戏展示 - KV背景 + Logo + 按钮
const steamUrl = 'https://store.steampowered.com/app/4369260/Act';
const afdianUrl = 'https://ifdian.net/a/paperlens';
---
<section class="hero" id="hero">
  <div class="overlay"></div>
  <div class="content">
    <!-- h1：页面主标题，用 Logo 图片的 alt 文本作为语义内容，视觉上无变化 -->
    <h1 class="hero-logo">
      <img
        src="/Resources/logo.png"
        alt="Act! 细胞调律"
        class="logo"
      />
    </h1>
    <p class="tagline">试玩版现已开放</p>
    <p class="release">2027年初发售</p>
    <div class="buttons">
      <a href={steamUrl} target="_blank" rel="noopener noreferrer" class="btn btn-steam">
        Steam 试玩版
      </a>
      <a href={afdianUrl} target="_blank" rel="noopener noreferrer" class="btn btn-afdian">
        爱发电支持
      </a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: url('/Resources/KV1080P.png') center center / cover no-repeat;
    background-color: #0a0a12;
    padding-top: 56px;
  }

  .overlay {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center, rgba(0, 0, 0, 0.25) 0%, rgba(0, 0, 0, 0.55) 100%);
  }

  .content {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 2rem;
    max-width: 800px;
  }

  .hero-logo {
    margin: 0;
    font-size: inherit;
    font-weight: inherit;
    line-height: 0;
  }

  .logo {
    max-width: 90%;
    height: auto;
    width: 480px;
    margin-bottom: 2rem;
    filter: drop-shadow(0 0 24px rgba(0, 243, 255, 0.45));
  }

  .tagline {
    font-size: clamp(1.4rem, 4vw, 2.4rem);
    font-weight: 700;
    color: #00f3ff;
    text-shadow: 0 0 16px rgba(0, 243, 255, 0.6), 0 2px 4px rgba(0, 0, 0, 0.8);
    margin-bottom: 0.75rem;
    letter-spacing: 0.12em;
  }

  .release {
    font-size: clamp(1rem, 2.5vw, 1.4rem);
    color: #ffffff;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.8);
    margin-bottom: 3rem;
    opacity: 0.9;
  }

  .buttons {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
  }

  @media (min-width: 480px) {
    .buttons {
      flex-direction: row;
      justify-content: center;
    }
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 180px;
    padding: 0.85rem 2rem;
    border-radius: 999px;
    font-size: 1rem;
    font-weight: 700;
    color: #ffffff;
    text-decoration: none;
    letter-spacing: 0.05em;
    transition: transform 0.2s ease, box-shadow 0.2s ease, filter 0.2s ease;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.4);
  }

  .btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.5);
  }

  .btn:active {
    transform: translateY(0);
  }

  .btn-steam {
    background: linear-gradient(135deg, #1b2838 0%, #2a475e 100%);
    border: 2px solid rgba(255, 255, 255, 0.15);
  }

  .btn-steam:hover {
    filter: brightness(1.15);
  }

  .btn-afdian {
    background: linear-gradient(135deg, #946ce6 0%, #e94de7 100%);
    border: 2px solid rgba(255, 255, 255, 0.15);
  }

  .btn-afdian:hover {
    filter: brightness(1.1);
  }
</style>
