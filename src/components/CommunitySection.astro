---
// 第六部分：加入社群 - QQ群、B站、Discord
const qqGroup = '893086747';
const bilibiliUrl = 'https://space.bilibili.com/3546742811265924';
const discordUrl = 'https://discord.gg/FbgspVhv6c';
---
<section class="community" id="community">
  <div class="community-content">
    <h2 class="community-title" data-i18n="community.title">加入社群</h2>
    <div class="community-links">
      <div class="community-card">
        <span class="platform-icon qq-icon">QQ</span>
        <div class="platform-info">
          <span class="platform-name" data-i18n="community.qq">玩家QQ群</span>
          <span class="platform-detail" data-i18n="community.qqDetail">{qqGroup}</span>
        </div>
      </div>
      <a href={bilibiliUrl} target="_blank" rel="noopener noreferrer" class="community-card">
        <span class="platform-icon bili-icon">B</span>
        <div class="platform-info">
          <span class="platform-name" data-i18n="community.bilibili">Bilibili</span>
          <span class="platform-detail" data-i18n="community.bilibiliDetail">关注我们</span>
        </div>
      </a>
      <a href={discordUrl} target="_blank" rel="noopener noreferrer" class="community-card">
        <span class="platform-icon dc-icon">DC</span>
        <div class="platform-info">
          <span class="platform-name" data-i18n="community.discord">Discord</span>
          <span class="platform-detail" data-i18n="community.discordDetail">加入服务器</span>
        </div>
      </a>
    </div>
  </div>
</section>

<style>
  .community {
    background-color: #000B24;
    min-height: 50vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem 2rem;
  }

  .community-content {
    max-width: 800px;
    width: 100%;
    text-align: center;
  }

  .community-title {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 700;
    color: #00f3ff;
    margin-bottom: 3rem;
    letter-spacing: 0.1em;
    text-shadow: 0 0 16px rgba(0, 243, 255, 0.5);
  }

  .community-links {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    align-items: center;
  }

  @media (min-width: 600px) {
    .community-links {
      flex-direction: row;
      justify-content: center;
    }
  }

  .community-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    padding: 1.2rem 1.8rem;
    min-width: 200px;
    text-decoration: none;
    color: #ffffff;
    transition: background 0.2s, border-color 0.2s, transform 0.2s;
    cursor: pointer;
  }

  .community-card:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(0, 243, 255, 0.3);
    transform: translateY(-2px);
  }

  .platform-icon {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    font-size: 0.85rem;
    letter-spacing: 0.02em;
  }

  .qq-icon {
    background: linear-gradient(135deg, #12b7f3, #00a2e8);
    color: #ffffff;
  }

  .bili-icon {
    background: linear-gradient(135deg, #fb7299, #e04f6e);
    color: #ffffff;
    font-size: 1.2rem;
  }

  .dc-icon {
    background: linear-gradient(135deg, #5865f2, #4752c6);
    color: #ffffff;
  }

  .platform-info {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .platform-name {
    font-size: 0.9rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.9);
  }

  .platform-detail {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.5);
  }
</style>
