---
// 顶端导航栏 - 主页链接 + 语言切换
---
<nav class="navbar" id="navbar">
  <div class="navbar-content">
    <a href="/" class="navbar-brand">
      <img src="/Resources/icon.png" alt="" class="navbar-icon" />
      <span>Act!</span>
    </a>
    <div class="navbar-links">
      <a href="#hero" class="navbar-link" data-i18n="nav.home">主页</a>
      <div class="lang-switcher">
        <button class="lang-btn active" data-lang="zh">中</button>
        <button class="lang-btn" data-lang="en">EN</button>
        <button class="lang-btn" data-lang="ja">日</button>
      </div>
    </div>
  </div>
</nav>

<script>
  document.querySelectorAll('.lang-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const lang = btn.getAttribute('data-lang');
      window.dispatchEvent(new CustomEvent('langChange', { detail: { lang } }));
    });
  });
</script>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background: rgba(10, 10, 18, 0.6);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .navbar-content {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 56px;
    padding: 0 2rem;
  }

  .navbar-brand {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
  }

  .navbar-icon {
    width: 32px;
    height: 32px;
    object-fit: contain;
  }

  .navbar-brand span {
    font-size: 1.5rem;
    font-weight: 800;
    color: #00f3ff;
    letter-spacing: 0.08em;
    text-shadow: 0 0 12px rgba(0, 243, 255, 0.4);
  }

  .navbar-links {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .navbar-link {
    color: rgba(255, 255, 255, 0.75);
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    transition: color 0.2s;
  }

  .navbar-link:hover {
    color: #00f3ff;
  }

  .lang-switcher {
    display: flex;
    gap: 0.25rem;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 6px;
    padding: 2px;
  }

  .lang-btn {
    background: transparent;
    border: none;
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.8rem;
    font-weight: 600;
    padding: 4px 10px;
    border-radius: 4px;
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
  }

  .lang-btn:hover {
    color: rgba(255, 255, 255, 0.8);
  }

  .lang-btn.active {
    background: rgba(0, 243, 255, 0.15);
    color: #00f3ff;
  }
</style>
