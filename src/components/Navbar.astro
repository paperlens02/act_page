---
// 顶端导航栏 - 目前只有"主页"链接，后续可扩展
---
<nav class="navbar" id="navbar">
  <div class="navbar-content">
    <a href="/" class="navbar-brand">Act!</a>
    <div class="navbar-links">
      <a href="#hero" class="navbar-link">主页</a>
    </div>
  </div>
</nav>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background: rgba(10, 10, 18, 0.6);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .navbar-content {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 56px;
    padding: 0 2rem;
  }

  .navbar-brand {
    font-size: 1.5rem;
    font-weight: 800;
    color: #00f3ff;
    text-decoration: none;
    letter-spacing: 0.08em;
    text-shadow: 0 0 12px rgba(0, 243, 255, 0.4);
  }

  .navbar-links {
    display: flex;
    gap: 2rem;
  }

  .navbar-link {
    color: rgba(255, 255, 255, 0.75);
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    transition: color 0.2s;
  }

  .navbar-link:hover {
    color: #00f3ff;
  }
</style>
