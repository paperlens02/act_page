---
// 第三部分：曲目介绍 - 自动读取 Songs 目录，横向滚动曲目列表
import fs from 'node:fs';
import path from 'node:path';

const songsDir = path.join(process.cwd(), 'public/Resources/Songs');
const metaFiles = fs.readdirSync(songsDir)
  .filter(f => f.startsWith('meta_') && f.endsWith('.json'))
  .sort();

const songs = metaFiles.map(f => {
  const raw = fs.readFileSync(path.join(songsDir, f), 'utf-8');
  const data = JSON.parse(raw);
  const songKey = f.slice(5, -5);
  return {
    name: data.songName,
    artist: data.artist,
    cover: `/Resources/Songs/cover_${songKey}.png`,
  };
});
---
<section class="songs snap-section" id="songs">
  <img id="songBg" class="song-bg" src={songs[0]?.cover ?? ''} alt="歌曲封面背景" aria-hidden="true" />
  <div class="songs-inner">
    <h2 class="songs-title song-reveal" data-i18n="song.title">精选优质曲目</h2>
    <div class="carousel-wrapper">
      <button class="carousel-arrow carousel-arrow-left" id="arrowLeft" aria-label="Previous">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
      </button>
      <div class="carousel-container" id="carouselContainer">
        <div class="carousel-track" id="carouselTrack">
          {songs.map((song, i) => (
            <div
              class:list={['carousel-item', { active: i === 0 }]}
              style={`--i: ${i}`}
              data-index={i}
              data-name={song.name}
              data-artist={song.artist}
              data-cover={song.cover}
            >
              <img src={song.cover} alt={song.name} loading="lazy" draggable="false" />
            </div>
          ))}
        </div>
      </div>
      <button class="carousel-arrow carousel-arrow-right" id="arrowRight" aria-label="Next">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
      </button>
    </div>
    <div class="song-info song-reveal" id="songInfo" style="animation-delay: 0.5s">
      <h3 class="song-name" id="songName">{songs[0]?.name ?? ''}</h3>
      <p class="song-artist" id="songArtist">{songs[0]?.artist ?? ''}</p>
    </div>
  </div>
</section>

<script>
  const items = document.querySelectorAll('.carousel-item');
  const track = document.getElementById('carouselTrack');
  const container = document.getElementById('carouselContainer');
  const songNameEl = document.getElementById('songName');
  const songArtistEl = document.getElementById('songArtist');
  const arrowLeft = document.getElementById('arrowLeft');
  const arrowRight = document.getElementById('arrowRight');

  if (items.length > 0 && track && container && songNameEl && songArtistEl) {
    let currentIndex = 0;
    let timer = 0;
    let isDragging = false;
    let startX = 0;
    let startTranslate = 0;
    let currentTranslate = 0;

    function getTranslateX() {
      const style = window.getComputedStyle(track);
      const matrix = new DOMMatrix(style.transform);
      return matrix.m41;
    }

    function selectSong(index) {
      currentIndex = index;
      items.forEach((item, i) => {
        item.classList.toggle('active', i === index);
      });
      const activeItem = items[index];
      // 文字切换动画：先淡出 → 替换 → 淡入
      songNameEl.classList.add('is-switching');
      songArtistEl.classList.add('is-switching');
      setTimeout(() => {
        songNameEl.textContent = activeItem.dataset.name || '';
        songArtistEl.textContent = activeItem.dataset.artist || '';
        songNameEl.classList.remove('is-switching');
        songArtistEl.classList.remove('is-switching');
      }, 180);
      const songBgEl = document.getElementById('songBg');
      if (songBgEl) songBgEl.src = activeItem.dataset.cover || '';
      const containerWidth = container.offsetWidth;
      const itemLeft = activeItem.offsetLeft;
      const itemWidth = activeItem.offsetWidth;
      const offset = containerWidth / 2 - itemLeft - itemWidth / 2;
      track.style.transition = 'transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94)';
      track.style.transform = 'translateX(' + offset + 'px)';
      currentTranslate = offset;
    }

    function autoRotate() {
      currentIndex = (currentIndex + 1) % items.length;
      selectSong(currentIndex);
    }

    function prevSong() {
      currentIndex = (currentIndex - 1 + items.length) % items.length;
      selectSong(currentIndex);
    }

    function nextSong() {
      currentIndex = (currentIndex + 1) % items.length;
      selectSong(currentIndex);
    }

    function resetTimer() {
      clearInterval(timer);
      timer = setInterval(autoRotate, 4000);
    }

    timer = setInterval(autoRotate, 4000);

    // Arrow buttons
    if (arrowLeft) arrowLeft.addEventListener('click', () => { resetTimer(); prevSong(); });
    if (arrowRight) arrowRight.addEventListener('click', () => { resetTimer(); nextSong(); });

    // Click to select
    items.forEach((item, i) => {
      item.addEventListener('click', () => {
        resetTimer();
        selectSong(i);
      });
    });

    // Mouse drag
    container.addEventListener('mousedown', (e) => {
      isDragging = true;
      startX = e.clientX;
      startTranslate = getTranslateX();
      track.style.transition = 'none';
      container.style.cursor = 'grabbing';
      resetTimer();
    });

    document.addEventListener('mousemove', (e) => {
      if (!isDragging) return;
      const dx = e.clientX - startX;
      currentTranslate = startTranslate + dx;
      track.style.transform = 'translateX(' + currentTranslate + 'px)';
    });

    document.addEventListener('mouseup', () => {
      if (!isDragging) return;
      isDragging = false;
      container.style.cursor = '';
      track.style.transition = 'transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94)';

      // Find nearest item
      const containerCenter = container.offsetWidth / 2;
      let nearestIndex = 0;
      let nearestDist = Infinity;
      items.forEach((item, i) => {
        const itemCenter = item.offsetLeft + item.offsetWidth / 2 + currentTranslate;
        const dist = Math.abs(itemCenter - containerCenter);
        if (dist < nearestDist) {
          nearestDist = dist;
          nearestIndex = i;
        }
      });
      selectSong(nearestIndex);
    });

    // Touch drag
    container.addEventListener('touchstart', (e) => {
      isDragging = true;
      startX = e.touches[0].clientX;
      startTranslate = getTranslateX();
      track.style.transition = 'none';
      resetTimer();
    });

    container.addEventListener('touchmove', (e) => {
      if (!isDragging) return;
      const dx = e.touches[0].clientX - startX;
      currentTranslate = startTranslate + dx;
      track.style.transform = 'translateX(' + currentTranslate + 'px)';
    });

    container.addEventListener('touchend', () => {
      if (!isDragging) return;
      isDragging = false;
      track.style.transition = 'transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94)';
      const containerCenter = container.offsetWidth / 2;
      let nearestIndex = 0;
      let nearestDist = Infinity;
      items.forEach((item, i) => {
        const itemCenter = item.offsetLeft + item.offsetWidth / 2 + currentTranslate;
        const dist = Math.abs(itemCenter - containerCenter);
        if (dist < nearestDist) {
          nearestDist = dist;
          nearestIndex = i;
        }
      });
      selectSong(nearestIndex);
    });

    selectSong(0);
    window.addEventListener('resize', () => selectSong(currentIndex));
  }
</script>

<style>
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: var(--to-opacity, 1); transform: translateY(0); }
  }

  .songs {
    position: relative;
    overflow: hidden;
    background-color: #081020;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 80px 2rem 10rem;
    position: relative;
  }

  .songs::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 160px;
    background: linear-gradient(to bottom, rgba(13, 26, 46, 0) 0%, rgba(13, 26, 46, 1) 100%);
    z-index: 2;
    pointer-events: none;
  }

  .song-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: blur(15px) brightness(0.4) contrast(1) saturate(1.5);
    transform: scale(1);
    transition: opacity 0.5s ease;
    z-index: 0;
    pointer-events: none;
  }

  .songs-inner {
    position: relative;
    z-index: 1;
    max-width: 1200px;
    width: 100%;
    text-align: center;
  }

  .songs-title {
    font-size: clamp(1.6rem, 3.5vw, 2.4rem);
    font-weight: 700;
    color: #00f3ff;
    margin-bottom: 2.5rem;
    letter-spacing: 0.08em;
    text-shadow: 0 0 12px rgba(0, 243, 255, 0.4);
  }

  /* Carousel wrapper with arrows */
  .carousel-wrapper {
    position: relative;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .carousel-arrow {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid rgba(0, 243, 255, 0.3);
    background: rgba(0, 243, 255, 0.08);
    color: #00f3ff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s, border-color 0.2s, transform 0.2s;
    z-index: 3;
  }

  .carousel-arrow:hover {
    background: rgba(0, 243, 255, 0.2);
    border-color: #00f3ff;
    transform: scale(1.1);
  }

  .carousel-container {
    flex: 1;
    overflow: hidden;
    position: relative;
    padding: 2rem 0;
    cursor: grab;
    user-select: none;
    -webkit-user-select: none;
  }

  .carousel-track {
    display: flex;
    gap: 2rem;
    padding: 0 1rem;
    transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    will-change: transform;
  }

  .carousel-item {
    flex-shrink: 0;
    width: 168px;
    height: 168px;
    border-radius: 14px;
    overflow: hidden;
    cursor: pointer;
    transition: transform 0.4s ease, opacity 0.4s ease, box-shadow 0.4s ease, filter 0.3s ease;
    opacity: 0.45;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
    user-select: none;
    -webkit-user-select: none;
    /* S3: 入场动画（由 IntersectionObserver 在 .songs.is-inview 时触发） */
    animation: fadeInUp 0.7s cubic-bezier(0.2, 0.7, 0.3, 1) backwards;
    animation-play-state: paused;
    animation-delay: calc(var(--i, 0) * 0.06s);
    --to-opacity: 0.45;
  }
  .songs.is-inview .carousel-item {
    animation-play-state: running;
  }

  /* S2: hover 抬升（仅非 active 时） */
  .carousel-item:not(.active):hover {
    transform: translateY(-4px) scale(1.05);
    opacity: 0.85;
    filter: brightness(1.1);
    box-shadow: 0 8px 20px rgba(0, 243, 255, 0.25);
  }

  .carousel-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    -webkit-user-drag: none;
    user-select: none;
    -webkit-user-select: none;
  }

  .carousel-item.active {
    transform: scale(1.35);
    opacity: 1;
    box-shadow: 0 0 24px rgba(0, 243, 255, 0.35), 0 4px 16px rgba(0, 0, 0, 0.4);
    z-index: 2;
    border: 2px solid rgba(0, 243, 255, 0.5);
  }

  .song-info {
    margin-top: 3rem;
  }

  .song-name {
    font-size: clamp(1.2rem, 2.5vw, 1.6rem);
    font-weight: 700;
    color: #ffffff;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.6);
    margin-bottom: 0.4rem;
    transition: opacity 0.22s ease, transform 0.22s ease;
  }

  .song-artist {
    font-size: clamp(0.85rem, 1.5vw, 1rem);
    color: rgba(255, 255, 255, 0.6);
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.5);
    transition: opacity 0.22s ease, transform 0.22s ease;
  }

  /* 曲目切换时文字淡出+上移 */
  .song-name.is-switching,
  .song-artist.is-switching {
    opacity: 0;
    transform: translateY(-6px);
    transition-duration: 0.18s;
  }

  /* 歌曲标题与信息入场（由 IntersectionObserver 触发） */
  .song-reveal {
    opacity: 0;
    will-change: transform, opacity;
  }
  .song-reveal.is-visible {
    animation: fadeInUp 0.9s cubic-bezier(0.2, 0.7, 0.3, 1) forwards;
    --to-opacity: 1;
  }

  @media (max-width: 600px) {
    .carousel-item {
      width: 126px;
      height: 126px;
      border-radius: 10px;
    }
    .carousel-track {
      gap: 1rem;
    }
    .carousel-item.active {
      transform: scale(1.25);
    }
    .carousel-arrow {
      width: 36px;
      height: 36px;
    }
  }
</style>
