---
// 玩法介绍部分 - 接收 props：背景色、标题、正文、section ID
const {
  background = '#0d1a2e',
  backgroundImage = '',
  title = '',
  text = '',
  sectionId = '',
  titleI18n = '',
  textI18n = '',
  nextBg = '',
} = Astro.props;
---
<section
  class:list={['gameplay', 'snap-section', { 'has-next-divider': !!nextBg }]}
  id={sectionId}
  style={`background-color: ${background};${backgroundImage ? " background-image: url('" + backgroundImage + "'); background-size: cover; background-position: center; background-repeat: no-repeat;" : ""}${nextBg ? " --next-bg: " + nextBg + ";" : ""}`}>
  <div class="gameplay-content">
    <h2 class="gameplay-title" data-i18n={titleI18n}>{title}</h2>
    <p class="gameplay-text" data-i18n-html={textI18n}>{text}</p>
  </div>
</section>

<style>
  .gameplay {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 5rem 2rem 10rem;
    position: relative;
  }

  .gameplay-content {
    max-width: 700px;
    width: 100%;
    text-align: center;
  }

  .gameplay-title {
    font-size: clamp(1.6rem, 3.5vw, 2.4rem);
    font-weight: 700;
    color: #00f3ff;
    margin-bottom: 2rem;
    letter-spacing: 0.08em;
    text-shadow: 0 0 12px rgba(0, 243, 255, 0.4);
  }

  .gameplay-text {
    font-size: clamp(1rem, 2vw, 1.15rem);
    line-height: 2;
    color: rgba(255, 255, 255, 0.75);
    letter-spacing: 0.03em;
  }

  /* 玩法 section 之间的过渡渐变 */
  .gameplay.has-next-divider::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 160px;
    background: linear-gradient(to bottom, transparent 0%, var(--next-bg, rgba(26, 8, 40, 1)) 100%);
    z-index: 2;
    pointer-events: none;
  }
</style>
