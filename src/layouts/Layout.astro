---
import Navbar from '../components/Navbar.astro';
import zh from '../i18n/zh.json';
import en from '../i18n/en.json';
import ja from '../i18n/ja.json';

const { title = 'Act! 细胞调律 | 手柄音游 官方网站 | Steam试玩版已开放' } = Astro.props;

const siteUrl = 'https://paperactgames.com';
const description = '自由输入手柄音游《Act! 细胞调律》Steam免费试玩开放中！完全自由的输入策略，轻松沉浸的手柄体验；严选优质曲目，并内置自定义编辑器；明快而深邃的碎片式剧情、充满神秘的收集养成——立即前往Steam免费下载！';
const ogImage = '/Resources/KV1080P.png';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;

const translations = { zh, en, ja };
---

<!DOCTYPE html>
<html lang="zh-CN" data-lang="zh">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <meta name="description" content={description} />
  <meta name="keywords" content="Act,细胞调律,手柄音游,音游,节奏游戏,试玩版,Steam,paperactgames,controller rhythm game,handheld rhythm game" />
  <meta name="author" content="PaperAct / 纸张lens" />
  <title>{title}</title>

  <link rel="canonical" href={canonicalUrl} />
  <link rel="alternate" hreflang="zh" href={siteUrl + '/'} />
  <link rel="alternate" hreflang="en" href={siteUrl + '/?lang=en'} />
  <link rel="alternate" hreflang="ja" href={siteUrl + '/?lang=ja'} />
  <link rel="alternate" hreflang="x-default" href={siteUrl + '/'} />
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" type="image/png" href="/Resources/icon.png" sizes="512x512" />
  <link rel="apple-touch-icon" href="/Resources/icon.png" />

  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Act! 细胞调律" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={new URL(ogImage, siteUrl).href} />
  <meta property="og:locale" content="zh_CN" />
  <meta property="og:locale:alternate" content="en_US" />
  <meta property="og:locale:alternate" content="ja_JP" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={new URL(ogImage, siteUrl).href} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "VideoGame",
    "name": "Act! 细胞调律",
    "alternateName": "Act!",
    "description": description,
    "url": siteUrl,
    "image": new URL(ogImage, siteUrl).href,
    "genre": ["Rhythm", "Music"],
    "gamePlatform": ["PC", "Steam"],
    "applicationCategory": "Game",
    "operatingSystem": "Windows",
    "publisher": {
      "@type": "Organization",
      "name": "PaperAct",
      "url": siteUrl
    },
    "author": {
      "@type": "Person",
      "name": "纸张lens",
      "url": "https://x.com/paperlens1"
    },
    "offers": {
      "@type": "Offer",
      "url": "https://store.steampowered.com/app/4369260/Act",
      "price": "0",
      "priceCurrency": "USD",
      "availability": "https://schema.org/PreOrder"
    }
  })}></script>
</head>
<body>
  <Navbar />
  <slot />

  <script define:vars={{ translations }}>
    const i18nData = translations;
    let currentLang = localStorage.getItem('lang') || 'zh';

    function applyLang(lang) {
      currentLang = lang;
      localStorage.setItem('lang', lang);
      document.documentElement.setAttribute('data-lang', lang);
      document.documentElement.setAttribute('lang', lang === 'zh' ? 'zh-CN' : lang);
      
      document.querySelectorAll('[data-i18n]').forEach(el => {
        const key = el.getAttribute('data-i18n');
        const value = getNestedValue(i18nData[lang], key);
        if (value !== undefined) {
          if (el.tagName === 'INPUT' || el.tagName === 'TEXTAREA') {
            el.placeholder = value;
          } else {
            el.textContent = value;
          }
        }
      });

      document.querySelectorAll('[data-i18n-html]').forEach(el => {
        const key = el.getAttribute('data-i18n-html');
        const value = getNestedValue(i18nData[lang], key);
        if (value !== undefined) {
          el.innerHTML = value;
        }
      });

      document.querySelectorAll('.lang-btn').forEach(btn => {
        btn.classList.toggle('active', btn.getAttribute('data-lang') === lang);
      });

      // Hide/show elements based on data-lang-hide
      document.querySelectorAll('[data-lang-hide]').forEach(el => {
        const hiddenLangs = el.getAttribute('data-lang-hide').split(',');
        el.style.display = hiddenLangs.includes(lang) ? 'none' : '';
      });

      // Switch logo based on language
      document.querySelectorAll('[data-logo-lang]').forEach(img => {
        img.style.display = img.getAttribute('data-logo-lang') === lang ? 'block' : 'none';
      });
    }

    function getNestedValue(obj, path) {
      return path.split('.').reduce((acc, part) => acc && acc[part], obj);
    }

    window.addEventListener('DOMContentLoaded', () => applyLang(currentLang));
    window.addEventListener('langChange', (e) => applyLang(e.detail.lang));
  </script>
</body>
</html>

<style is:global>
  *, *::before, *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }
  html {
    scroll-behavior: smooth;
    scroll-snap-type: y mandatory;
    overflow-y: scroll;
  }
  html, body {
    height: 100%;
    font-family: 'Microsoft YaHei', 'PingFang SC', 'Noto Sans SC', sans-serif;
    background: #0a0a12;
    color: #ffffff;
    overflow-x: hidden;
  }
  ::-webkit-scrollbar {
    width: 6px;
  }
  ::-webkit-scrollbar-track {
    background: transparent;
  }
  ::-webkit-scrollbar-thumb {
    background: rgba(0, 243, 255, 0.3);
    border-radius: 3px;
  }
  .snap-section {
    min-height: 100vh;
    scroll-snap-align: start;
  }
</style>
