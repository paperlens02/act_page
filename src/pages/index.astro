---
// 首页：Act! 细胞调律
const pageTitle = 'Act! 细胞调律';
const steamUrl = 'https://store.steampowered.com/app/4369260/Act';
const afdianUrl = 'https://ifdian.net/a/paperlens';
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Act! 细胞调律 - 无轨下落式节奏游戏，试玩版现已开放，2027年初发售。" />
  <title>{pageTitle}</title>
  <link rel="icon" type="image/png" href="/Resources/icon.png" />
</head>
<body>
  <main class="hero">
    <div class="overlay"></div>
    <div class="content">
      <img
        src="/Resources/logo.png"
        alt="Act! 细胞调律 游戏 Logo"
        class="logo"
        width="600"
        height="200"
      />
      <p class="tagline">试玩版现已开放</p>
      <p class="release">2027年初发售</p>
      <div class="buttons">
        <a href={steamUrl} target="_blank" rel="noopener noreferrer" class="btn btn-steam">
          Steam 试玩版
        </a>
        <a href={afdianUrl} target="_blank" rel="noopener noreferrer" class="btn btn-afdian">
          爱发电支持
        </a>
      </div>
    </div>
  </main>
</body>
</html>

<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html, body {
    height: 100%;
    font-family: 'Microsoft YaHei', 'PingFang SC', 'Noto Sans SC', sans-serif;
  }

  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: url('/Resources/KV1080P.png') center center / cover no-repeat;
    background-color: #0a0a12;
  }

  .overlay {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center, rgba(0, 0, 0, 0.3) 0%, rgba(0, 0, 0, 0.6) 100%);
  }

  .content {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 2rem;
    max-width: 800px;
  }

  .logo {
    max-width: 90%;
    height: auto;
    width: 520px;
    margin-bottom: 2rem;
    filter: drop-shadow(0 0 20px rgba(0, 243, 255, 0.4));
  }

  .tagline {
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    font-weight: 700;
    color: #00f3ff;
    text-shadow: 0 0 16px rgba(0, 243, 255, 0.6), 0 2px 4px rgba(0, 0, 0, 0.8);
    margin-bottom: 0.75rem;
    letter-spacing: 0.1em;
  }

  .release {
    font-size: clamp(1.1rem, 2.5vw, 1.5rem);
    color: #ffffff;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.8);
    margin-bottom: 3rem;
    opacity: 0.95;
  }

  .buttons {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
  }

  @media (min-width: 480px) {
    .buttons {
      flex-direction: row;
      justify-content: center;
    }
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 180px;
    padding: 0.9rem 2rem;
    border-radius: 999px;
    font-size: 1rem;
    font-weight: 700;
    color: #ffffff;
    text-decoration: none;
    letter-spacing: 0.05em;
    transition: transform 0.2s ease, box-shadow 0.2s ease, filter 0.2s ease;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.4);
  }

  .btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.5);
  }

  .btn:active {
    transform: translateY(0);
  }

  .btn-steam {
    background: linear-gradient(135deg, #1b2838 0%, #2a475e 100%);
    border: 2px solid rgba(255, 255, 255, 0.2);
  }

  .btn-steam:hover {
    filter: brightness(1.15);
  }

  .btn-afdian {
    background: linear-gradient(135deg, #946ce6 0%, #e94de7 100%);
    border: 2px solid rgba(255, 255, 255, 0.2);
  }

  .btn-afdian:hover {
    filter: brightness(1.1);
  }
</style>
