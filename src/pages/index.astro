---
// 首页：组装所有区域组件
import Layout from '../layouts/Layout.astro';
import HeroSection from '../components/HeroSection.astro';
import CharacterSection from '../components/CharacterSection.astro';
import SongSection from '../components/SongSection.astro';
import GameplaySection from '../components/GameplaySection.astro';
---
<Layout title="Act! 细胞调律 官方网站 | Steam试玩版已开放">
  <HeroSection />
  <CharacterSection />
  <SongSection />
  <GameplaySection
    background="#0d1a2e"
    backgroundImage="/Resources/bg_tunespace.png"
    title="Tune玩法"
    text="创新无轨音游：任何按键均可触发判定，躺着也能打音游。<br>音符关联性：红色连打、绿色阶梯、蓝色交互，形成按键策略。<br>多维评分：关联性输入不影响技术分，仅获得艺术分奖励。<br>积累艺术分，推进剧情，兑换收集品。"
    sectionId="tune"
    titleI18n="gameplay.tune.title"
    textI18n="gameplay.tune.desc"
    nextBg="#1a0828"
  />
  <GameplaySection
    background="#1a0828"
    title="Fight玩法"
    text="全新战斗节奏玩法：在旋律中迎战敌人。<br>三色技能：Beat 重击、Flow 连斩、Tech 巧技，对应不同攻击风格。<br>蓄力与终结：积攒能量释放终结技，一击制敌。<br>英雄与怪物的攻防博弈，在节奏中展开热血战斗。"
    sectionId="fight"
    titleI18n="gameplay.fight.title"
    textI18n="gameplay.fight.desc"
  />

<script data-reveal-observer>
  // G1: 滚动触发入场动画（IntersectionObserver）
  if ('IntersectionObserver' in window) {
    const revealObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            revealObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15, rootMargin: '0px 0px -10% 0px' }
    );
    document.querySelectorAll('.char-reveal, .song-reveal').forEach((el) => {
      revealObserver.observe(el);
    });

    // S3: 在 .songs 进入视口时启动 carousel-item 入场动画
    const songsEl = document.querySelector('.songs');
    if (songsEl) {
      const songsObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              songsEl.classList.add('is-inview');
              songsObserver.unobserve(songsEl);
            }
          });
        },
        { threshold: 0.2 }
      );
      songsObserver.observe(songsEl);
    }
  } else {
    // 无 IO 支持时直接显示所有入场元素
    document.querySelectorAll('.char-reveal, .song-reveal').forEach((el) => {
      el.classList.add('is-visible');
      el.style.opacity = '';
    });
    const songsEl = document.querySelector('.songs');
    if (songsEl) songsEl.classList.add('is-inview');
  }
</script>
</Layout>
